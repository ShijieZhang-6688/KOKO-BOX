.town-page {
  min-height: 100vh;
  padding: 24rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.96), transparent 28%),
    linear-gradient(180deg, #f9fbff 0%, #eef3fb 100%);
  box-sizing: border-box;
}

.town-hero {
  padding: 24rpx 28rpx;
  border: 2rpx solid rgba(126, 138, 168, 0.14);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(61, 82, 132, 0.08);
}

.town-hero__eyebrow {
  color: #7b87a6;
  font-size: 24rpx;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.town-hero__title {
  margin-top: 8rpx;
  color: #20304d;
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.2;
}

.town-hero__copy {
  margin-top: 10rpx;
  color: #6a7896;
  font-size: 26rpx;
  line-height: 1.55;
}

.town-map {
  position: relative;
  height: 1080rpx;
  margin-top: 20rpx;
  overflow: hidden;
  border-radius: 40rpx;
  border: 2rpx solid rgba(126, 138, 168, 0.14);
  background:
    radial-gradient(circle at 50% 22%, rgba(255, 255, 255, 0.48), transparent 24%),
    radial-gradient(circle at 18% 82%, rgba(149, 215, 144, 0.28), transparent 20%),
    radial-gradient(circle at 82% 80%, rgba(141, 210, 151, 0.24), transparent 18%),
    linear-gradient(180deg, #cbecff 0%, #dff3ff 22%, #9fda8f 22%, #6dbd6e 100%);
  box-shadow: 0 30rpx 70rpx rgba(61, 82, 132, 0.1);
}

.town-map__sky-glow {
  position: absolute;
  left: 50%;
  top: 44rpx;
  width: 520rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.62), rgba(255, 255, 255, 0));
  transform: translateX(-50%);
}

.town-map__cloudbank {
  position: absolute;
  top: 62rpx;
  width: 170rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow:
    30rpx -10rpx 0 12rpx rgba(255, 255, 255, 0.82),
    74rpx 0 0 6rpx rgba(255, 255, 255, 0.78);
  opacity: 0.9;
}

.town-map__cloudbank--left {
  left: 34rpx;
}

.town-map__cloudbank--right {
  right: 42rpx;
}

.town-map__treeline {
  position: absolute;
  left: -40rpx;
  right: -40rpx;
  top: 106rpx;
  height: 180rpx;
  border-radius: 0 0 120rpx 120rpx;
  background:
    radial-gradient(circle at 8% 70%, #74c984 0, #74c984 46rpx, transparent 47rpx),
    radial-gradient(circle at 18% 44%, #5bb870 0, #5bb870 62rpx, transparent 63rpx),
    radial-gradient(circle at 32% 64%, #6ac27b 0, #6ac27b 52rpx, transparent 53rpx),
    radial-gradient(circle at 50% 46%, #5ab56e 0, #5ab56e 72rpx, transparent 73rpx),
    radial-gradient(circle at 66% 62%, #67c07b 0, #67c07b 56rpx, transparent 57rpx),
    radial-gradient(circle at 80% 40%, #57b06c 0, #57b06c 70rpx, transparent 71rpx),
    radial-gradient(circle at 92% 70%, #74c984 0, #74c984 46rpx, transparent 47rpx);
  opacity: 0.95;
}

.town-map__plaza-shadow {
  position: absolute;
  left: 50%;
  top: 520rpx;
  width: 360rpx;
  height: 150rpx;
  border-radius: 50%;
  background: rgba(76, 123, 84, 0.14);
  transform: translateX(-50%);
  filter: blur(10rpx);
}

.town-map__grass-shadow {
  position: absolute;
  bottom: 154rpx;
  width: 210rpx;
  height: 110rpx;
  border-radius: 50%;
  background: rgba(77, 140, 82, 0.12);
  filter: blur(8rpx);
}

.town-map__grass-shadow--left {
  left: 18rpx;
}

.town-map__grass-shadow--right {
  right: 18rpx;
}

.town-map__path {
  position: absolute;
  z-index: 1;
  background: linear-gradient(180deg, #f8e8bd 0%, #ecd39d 100%);
  box-shadow:
    inset 0 6rpx 10rpx rgba(255, 255, 255, 0.34),
    0 12rpx 18rpx rgba(117, 101, 73, 0.12);
}

.town-map__path--left {
  left: 116rpx;
  top: 322rpx;
  width: 170rpx;
  height: 86rpx;
  border-radius: 999rpx 80rpx 80rpx 999rpx;
  transform: rotate(24deg);
}

.town-map__path--right {
  right: 108rpx;
  top: 318rpx;
  width: 176rpx;
  height: 86rpx;
  border-radius: 80rpx 999rpx 999rpx 80rpx;
  transform: rotate(-24deg);
}

.town-map__path--bottom {
  left: 252rpx;
  top: 640rpx;
  width: 106rpx;
  height: 234rpx;
  border-radius: 90rpx 90rpx 120rpx 120rpx;
}

.town-map__path--ring {
  left: 188rpx;
  top: 536rpx;
  width: 248rpx;
  height: 158rpx;
  border-radius: 999rpx;
  background: rgba(240, 217, 170, 0.82);
  box-shadow: inset 0 0 0 22rpx rgba(248, 232, 189, 0.96);
}

.town-map__path-dots {
  position: absolute;
  z-index: 2;
  background:
    radial-gradient(circle, rgba(255, 255, 255, 0.52) 0, rgba(255, 255, 255, 0.52) 10rpx, transparent 11rpx);
  background-size: 36rpx 36rpx;
  opacity: 0.45;
}

.town-map__path-dots--left {
  left: 146rpx;
  top: 334rpx;
  width: 132rpx;
  height: 64rpx;
  transform: rotate(24deg);
}

.town-map__path-dots--right {
  right: 138rpx;
  top: 332rpx;
  width: 138rpx;
  height: 64rpx;
  transform: rotate(-24deg);
}

.town-map__path-dots--bottom {
  left: 272rpx;
  top: 664rpx;
  width: 66rpx;
  height: 184rpx;
}

.pennant {
  position: absolute;
  z-index: 4;
  width: 24rpx;
  height: 48rpx;
}

.pennant__string {
  position: absolute;
  left: 50%;
  top: 0;
  width: 4rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 239, 0.9);
  transform: translateX(-50%);
}

.pennant__flag {
  position: absolute;
  left: 50%;
  top: 18rpx;
  width: 20rpx;
  height: 22rpx;
  border-radius: 4rpx 10rpx 10rpx 4rpx;
  transform: translateX(-50%);
  box-shadow: 0 6rpx 10rpx rgba(84, 102, 149, 0.1);
}

.pennant--coral .pennant__flag {
  background: linear-gradient(180deg, #ff9a82 0%, #ff7c65 100%);
}

.pennant--sun .pennant__flag {
  background: linear-gradient(180deg, #ffd782 0%, #f3bc53 100%);
}

.pennant--sky .pennant__flag {
  background: linear-gradient(180deg, #8fd8ff 0%, #67bdf5 100%);
}

.pennant--mint .pennant__flag {
  background: linear-gradient(180deg, #9ee6b2 0%, #67c987 100%);
}

.location {
  position: absolute;
  z-index: 5;
  transition: transform 180ms ease;
}

.location--square {
  z-index: 4;
}

.location--active {
  transform: translateY(-10rpx);
}

.location--active .building__label,
.location--active .building__label--square {
  background: linear-gradient(180deg, #ffffff 0%, #fff6da 100%);
  color: #3f5375;
  box-shadow: 0 14rpx 28rpx rgba(84, 102, 149, 0.16);
}

.location--active .building__shadow,
.location--active .square__shadow {
  background: rgba(61, 82, 102, 0.22);
}

.building,
.square {
  position: relative;
}

.building__shadow,
.square__shadow {
  position: absolute;
  left: 50%;
  bottom: -8rpx;
  border-radius: 999rpx;
  background: rgba(61, 82, 102, 0.16);
  transform: translateX(-50%);
  filter: blur(6rpx);
}

.building__shadow {
  width: 152rpx;
  height: 34rpx;
}

.square__shadow {
  width: 220rpx;
  height: 42rpx;
}

.building__roof,
.building__body,
.building__door,
.building__window,
.building__awning,
.building__counter,
.building__board,
.square__platform,
.square__ring,
.square__fountain-base,
.square__fountain-water,
.square__fountain-core,
.square__fountain-jet {
  position: absolute;
}

.building__label {
  position: absolute;
  left: 50%;
  bottom: -60rpx;
  min-width: 112rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #4d607e;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  transform: translateX(-50%);
  box-shadow: 0 10rpx 20rpx rgba(84, 102, 149, 0.1);
}

.building__label--square {
  bottom: -48rpx;
}

.building--home,
.building--shop,
.building--task {
  width: 180rpx;
  height: 172rpx;
}

.building--home .building__roof,
.building--task .building__roof {
  left: 18rpx;
  top: 0;
  width: 144rpx;
  height: 76rpx;
  border-radius: 32rpx 32rpx 22rpx 22rpx;
  transform: skewX(-8deg);
}

.building--shop .building__roof {
  left: 14rpx;
  top: 2rpx;
  width: 152rpx;
  height: 60rpx;
  border-radius: 26rpx;
}

.building--home .building__body,
.building--task .building__body,
.building--shop .building__body {
  left: 22rpx;
  top: 48rpx;
  width: 136rpx;
  height: 108rpx;
  border-radius: 28rpx;
  box-shadow:
    inset 0 8rpx 12rpx rgba(255, 255, 255, 0.28),
    0 16rpx 24rpx rgba(74, 88, 127, 0.14);
}

.building--home .building__roof {
  background: linear-gradient(180deg, #ffaf91 0%, #ee8666 100%);
}

.building--home .building__body {
  background: linear-gradient(180deg, #fff5ea 0%, #f8e6ce 100%);
}

.building--home .building__door {
  left: 74rpx;
  top: 96rpx;
  width: 30rpx;
  height: 60rpx;
  border-radius: 14rpx 14rpx 10rpx 10rpx;
  background: linear-gradient(180deg, #c88d69 0%, #ae7354 100%);
}

.building--home .building__window {
  top: 86rpx;
}

.building--home .building__window--left {
  left: 42rpx;
}

.building--home .building__window--right {
  right: 42rpx;
}

.building--shop .building__roof {
  background: linear-gradient(180deg, #8ec8ff 0%, #64a9f6 100%);
}

.building--shop .building__body {
  background: linear-gradient(180deg, #ffffff 0%, #eef5ff 100%);
}

.building--shop .building__awning {
  left: 24rpx;
  top: 58rpx;
  width: 132rpx;
  height: 30rpx;
  border-radius: 16rpx;
  background:
    linear-gradient(
      90deg,
      #ff8b9a 0,
      #ff8b9a 18%,
      #fff7f7 18%,
      #fff7f7 36%,
      #ff8b9a 36%,
      #ff8b9a 54%,
      #fff7f7 54%,
      #fff7f7 72%,
      #ff8b9a 72%,
      #ff8b9a 100%
    );
  box-shadow: 0 8rpx 14rpx rgba(100, 169, 246, 0.18);
}

.building--shop .building__counter {
  left: 40rpx;
  top: 116rpx;
  width: 98rpx;
  height: 22rpx;
  border-radius: 999rpx;
  background: #89cfa5;
}

.building--shop .building__window {
  top: 90rpx;
}

.building--shop .building__window--left {
  left: 38rpx;
}

.building--shop .building__window--right {
  right: 38rpx;
}

.building--task .building__roof {
  background: linear-gradient(180deg, #9b8cff 0%, #7363e9 100%);
}

.building--task .building__body {
  background: linear-gradient(180deg, #f6f2ff 0%, #e8e0ff 100%);
}

.building--task .building__board {
  left: 50%;
  top: 58rpx;
  width: 86rpx;
  height: 28rpx;
  border-radius: 14rpx;
  background: linear-gradient(180deg, #ffd58a 0%, #efb95e 100%);
  transform: translateX(-50%);
  box-shadow: 0 8rpx 16rpx rgba(115, 99, 233, 0.18);
}

.building--task .building__door {
  left: 72rpx;
  top: 96rpx;
  width: 36rpx;
  height: 60rpx;
  border-radius: 14rpx 14rpx 10rpx 10rpx;
  background: linear-gradient(180deg, #a488ed 0%, #7f68d4 100%);
}

.building--task .building__window {
  top: 92rpx;
}

.building--task .building__window--left {
  left: 38rpx;
}

.building--task .building__window--right {
  right: 38rpx;
}

.building__window {
  width: 24rpx;
  height: 30rpx;
  border-radius: 12rpx;
  background: linear-gradient(180deg, #ffffff 0%, #b9e5ff 100%);
  box-shadow: inset 0 4rpx 8rpx rgba(255, 255, 255, 0.4);
}

.square {
  width: 204rpx;
  height: 178rpx;
}

.square__tile {
  position: absolute;
  top: 54rpx;
  width: 20rpx;
  height: 20rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.45);
}

.square__tile--one {
  left: 42rpx;
}

.square__tile--two {
  left: 92rpx;
}

.square__tile--three {
  right: 42rpx;
}

.square__platform {
  left: 12rpx;
  top: 30rpx;
  width: 180rpx;
  height: 112rpx;
  border-radius: 42rpx;
  background: linear-gradient(180deg, #f6f8fb 0%, #e6ebf2 100%);
  box-shadow: 0 16rpx 24rpx rgba(84, 102, 149, 0.12);
}

.square__ring {
  left: 34rpx;
  top: 42rpx;
  width: 136rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #d7e1ec 0%, #c5d1df 100%);
}

.square__fountain-base {
  left: 68rpx;
  top: 58rpx;
  width: 68rpx;
  height: 46rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #dce7f5 0%, #c5d3e6 100%);
}

.square__fountain-water {
  left: 78rpx;
  top: 54rpx;
  width: 48rpx;
  height: 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #9fe4ff 0%, #61c6f8 100%);
  box-shadow: inset 0 6rpx 10rpx rgba(255, 255, 255, 0.4);
}

.square__fountain-core {
  left: 92rpx;
  top: 38rpx;
  width: 20rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f4fbff 0%, #dceeff 100%);
}

.square__ripple {
  position: absolute;
  left: 50%;
  top: 48rpx;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.48);
  transform: translateX(-50%);
}

.square__ripple--one {
  width: 62rpx;
  height: 24rpx;
}

.square__ripple--two {
  width: 84rpx;
  height: 34rpx;
  top: 44rpx;
  opacity: 0.72;
}

.square__fountain-jet {
  top: 18rpx;
  width: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(126, 214, 255, 0.78) 100%);
}

.square__fountain-jet--left {
  left: 82rpx;
  height: 34rpx;
  transform: rotate(-12deg);
}

.square__fountain-jet--center {
  left: 96rpx;
  height: 44rpx;
}

.square__fountain-jet--right {
  left: 110rpx;
  height: 34rpx;
  transform: rotate(12deg);
}

.tree {
  position: absolute;
  width: 94rpx;
  height: 132rpx;
  z-index: 3;
}

.tree--decor {
  z-index: 3;
}

.tree__shadow {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 70rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: rgba(61, 82, 102, 0.14);
  transform: translateX(-50%);
  filter: blur(4rpx);
}

.tree__trunk {
  position: absolute;
  left: 50%;
  bottom: 10rpx;
  width: 22rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #a77457 0%, #80523d 100%);
  transform: translateX(-50%);
}

.tree__crown {
  position: absolute;
  left: 50%;
  border-radius: 50%;
  transform: translateX(-50%);
}

.tree__crown--back {
  top: 14rpx;
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(180deg, #88d585 0%, #5bb570 100%);
}

.tree__crown--front {
  top: 0;
  width: 90rpx;
  height: 78rpx;
  background: linear-gradient(180deg, #a4e394 0%, #6fc66f 100%);
}

.grass-patch {
  position: absolute;
  z-index: 2;
  border-radius: 999rpx;
  background:
    radial-gradient(circle at 28% 50%, rgba(255, 255, 255, 0.22), transparent 24%),
    linear-gradient(180deg, #84d67f 0%, #59b660 100%);
  box-shadow: 0 10rpx 14rpx rgba(76, 137, 84, 0.12);
}

.flower {
  position: absolute;
  width: 28rpx;
  height: 28rpx;
  z-index: 6;
}

.flower__center {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #ffd96b;
  transform: translate(-50%, -50%);
}

.flower__petal {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.flower--pink .flower__petal {
  background: #ff9db7;
}

.flower--yellow .flower__petal {
  background: #ffe58b;
}

.flower--sky .flower__petal {
  background: #8fd6ff;
}

.flower__petal--top {
  left: 8rpx;
  top: 0;
}

.flower__petal--right {
  right: 0;
  top: 8rpx;
}

.flower__petal--bottom {
  left: 8rpx;
  bottom: 0;
}

.flower__petal--left {
  left: 0;
  top: 8rpx;
}

.stone {
  position: absolute;
  z-index: 4;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f5f7fa 0%, #d8dfe9 100%);
  box-shadow: 0 10rpx 16rpx rgba(84, 102, 149, 0.1);
}

.stone--large {
  width: 54rpx;
  height: 28rpx;
}

.stone--small {
  width: 38rpx;
  height: 22rpx;
}

.town-map__toast {
  position: absolute;
  left: 50%;
  top: 28rpx;
  z-index: 10;
  min-width: 180rpx;
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(37, 48, 71, 0.82);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
  transform: translateX(-50%);
  box-shadow: 0 14rpx 28rpx rgba(34, 47, 74, 0.2);
}

.town-map__hint {
  position: absolute;
  right: 24rpx;
  bottom: 24rpx;
  z-index: 8;
  max-width: 300rpx;
  padding: 16rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #5b6b88;
  font-size: 22rpx;
  line-height: 1.35;
  box-shadow: 0 12rpx 24rpx rgba(84, 102, 149, 0.1);
}

.square__fountain-water,
.square__ripple,
.square__fountain-jet--center {
  animation: fountainPulse 2.4s ease-in-out infinite;
}

.square__fountain-jet--left,
.square__fountain-jet--right {
  animation: fountainJet 1.8s ease-in-out infinite;
}

.tree--decor {
  animation: treeBob 3.6s ease-in-out infinite;
}

.tree--decor:nth-child(2n) {
  animation-duration: 4.2s;
}

.pennant {
  animation: pennantSway 2s ease-in-out infinite;
}

.flower {
  animation: flowerBob 3s ease-in-out infinite;
}

@keyframes fountainPulse {
  0%,
  100% {
    transform: translateX(-50%) scale(1);
    opacity: 0.9;
  }
  50% {
    transform: translateX(-50%) scale(1.08);
    opacity: 1;
  }
}

@keyframes fountainJet {
  0%,
  100% {
    opacity: 0.8;
    height: 34rpx;
  }
  50% {
    opacity: 1;
    height: 42rpx;
  }
}

@keyframes treeBob {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-6rpx);
  }
}

@keyframes pennantSway {
  0%,
  100% {
    transform: rotate(0deg);
  }
  50% {
    transform: rotate(7deg);
  }
}

@keyframes flowerBob {
  0%,
  100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-4rpx);
  }
}
