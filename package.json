{
  "name": "koko-box-ui-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:mp-weixin",
    "prepare:mp-weixin-assets": "node scripts/copy-tab-icons.mjs",
    "dev:mp-weixin": "cross-env UNI_INPUT_DIR=. uni dev -p mp-weixin --outDir unpackage/dist/mp-weixin",
    "build": "npm run build:mp-weixin",
    "build:mp-weixin": "cross-env UNI_INPUT_DIR=. uni build -p mp-weixin --outDir unpackage/dist/mp-weixin && npm run prepare:mp-weixin-assets"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@dcloudio/types": "^3.4.28",
    "@dcloudio/uni-app": "^3.0.0-5000720260410001",
    "@dcloudio/uni-components": "^3.0.0-5000720260410001",
    "@dcloudio/uni-mp-weixin": "^3.0.0-5000720260410001",
    "@dcloudio/vite-plugin-uni": "3.0.0-5000720260410001",
    "cross-env": "^7.0.3",
    "typescript": "^5.8.3",
    "vite": "5.2.8"
  }
}
